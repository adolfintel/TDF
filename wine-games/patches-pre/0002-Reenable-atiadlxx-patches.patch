From 445021829f1ca5907d92780b19ce6a0e77ad5b6a Mon Sep 17 00:00:00 2001
From: Federico Dossena <info@fdossena.com>
Date: Fri, 23 Jan 2026 05:59:30 +0100
Subject: [PATCH] Reenable atiadlxx patches

---
 wine-tkg-git/wine-tkg-patches/hotfixes/valve/hotfixes | 6 ------
 1 file changed, 6 deletions(-)

diff --git a/wine-tkg-git/wine-tkg-patches/hotfixes/valve/hotfixes b/wine-tkg-git/wine-tkg-patches/hotfixes/valve/hotfixes
index 3d9a065c..5431bb26 100644
--- a/wine-tkg-git/wine-tkg-patches/hotfixes/valve/hotfixes
+++ b/wine-tkg-git/wine-tkg-patches/hotfixes/valve/hotfixes
@@ -48,12 +48,6 @@ if [[ "$_plain_version" = *_10.0 ]]; then
     cp "$_where"/wine-tkg-patches/hotfixes/valve/fixes/0001-revert-icu-proton.mypatch "$_where"/
   fi
 
-  # Bleeding edge atiadlxx ADL2 changes are failing to build against current sniper container (and Archlinux alike), let's revert
-  if [[ "$_LOCAL_PRESET" = valve-exp-bleeding ]]; then
-    cp "$_where"/wine-tkg-patches/hotfixes/valve/fixes/0001-revert-atiadlxx-ADL2-2.myrevert "$_where"/
-    cp "$_where"/wine-tkg-patches/hotfixes/valve/fixes/0001-revert-atiadlxx-ADL2.myrevert "$_where"/
-  fi
-
   # Revert breaking change regarding linking against libopencl - https://github.com/ValveSoftware/wine/commit/f946d7c633088e7ee41da62dcbcb5a7480804d65
   # https://github.com/Frogging-Family/wine-tkg-git/issues/1467
   if [[ "$_LOCAL_PRESET" = valve-exp* ]] || ( cd "${srcdir}"/"${_winesrcdir}" && ( git merge-base --is-ancestor dd8d73ba895ac6de6c7f25a5b5f3dc7386882b6e HEAD || git merge-base --is-ancestor f946d7c633088e7ee41da62dcbcb5a7480804d65 HEAD )); then
-- 
2.52.0

